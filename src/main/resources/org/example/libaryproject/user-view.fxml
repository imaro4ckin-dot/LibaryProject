<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.libaryproject.UserController"
            stylesheets="@styles.css">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label text="Library" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="User" styleClass="role-badge"/>
            <Button text="Logout" onAction="#handleLogout" styleClass="logout-button"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="bookTable">
            <columns>
                <TableColumn fx:id="titleColumn"  text="Title"      prefWidth="200"/>
                <TableColumn fx:id="authorColumn" text="Author"     prefWidth="150"/>
                <TableColumn fx:id="statusColumn" text="Available?" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="Checkout Book" onAction="#handleCheckout"/>
            <Button text="Return Book"   onAction="#handleReturn"/>
        </HBox>
    </bottom>
</BorderPane>
