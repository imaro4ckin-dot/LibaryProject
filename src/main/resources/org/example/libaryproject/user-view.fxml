<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.libaryproject.UserController"
            stylesheets="@styles.css">
    <top>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Label text="Library" styleClass="screen-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search..." prefWidth="160"/>
            <Label fx:id="userLabel" styleClass="role-badge"/>
            <Button text="Change Password" onAction="#handleChangePassword" styleClass="logout-button"/>
            <Button text="Logout"          onAction="#handleLogout"         styleClass="logout-button"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE">

            <!-- Tab 1: Available books to browse and check out -->
            <Tab text="Available Books">
                <TableView fx:id="availableTable">
                    <columns>
                        <TableColumn fx:id="availTitleColumn"  text="Title"  prefWidth="280"/>
                        <TableColumn fx:id="availAuthorColumn" text="Author" prefWidth="200"/>
                    </columns>
                </TableView>
            </Tab>

            <!-- Tab 2: Books this user has checked out -->
            <Tab text="My Books">
                <TableView fx:id="myBooksTable">
                    <columns>
                        <TableColumn fx:id="myTitleColumn"   text="Title"    prefWidth="230"/>
                        <TableColumn fx:id="myAuthorColumn"  text="Author"   prefWidth="160"/>
                        <TableColumn fx:id="myDueDateColumn" text="Due Date" prefWidth="100"/>
                        <TableColumn fx:id="myStatusColumn"  text="Status"   prefWidth="90"/>
                    </columns>
                </TableView>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <HBox spacing="12" alignment="CENTER">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <Button text="Checkout Book" onAction="#handleCheckout"/>
            <Button text="Return Book"   onAction="#handleReturn"/>
        </HBox>
    </bottom>
</BorderPane>
