<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.libaryproject.ForgotPasswordController"
      stylesheets="@styles.css"
      alignment="CENTER_LEFT"
      spacing="14"
      prefWidth="380"
      prefHeight="340">

    <padding><Insets top="36" right="40" bottom="36" left="40"/></padding>

    <Label text="Reset Password" styleClass="login-title"/>
    <Label text="Enter your username to look up your security question." styleClass="login-subtitle" wrapText="true"/>

    <!-- Step 1: username lookup -->
    <VBox fx:id="step1Box" spacing="10" style="-fx-padding: 8 0 0 0;">
        <TextField fx:id="usernameField" promptText="Username"/>
        <Button text="Look Up" onAction="#handleLookup" maxWidth="Infinity" styleClass="login-button"/>
    </VBox>

    <!-- Step 2: answer + new password (hidden until step 1 passes) -->
    <VBox fx:id="step2Box" spacing="10" visible="false" managed="false">
        <Label fx:id="questionLabel" wrapText="true"
               style="-fx-font-weight: bold; -fx-text-fill: #1a1a1a;"/>
        <TextField    fx:id="answerField"      promptText="Your answer"/>
        <PasswordField fx:id="newPasswordField" promptText="New password"/>
        <PasswordField fx:id="confirmField"     promptText="Confirm new password"/>
        <Button text="Reset Password" onAction="#handleReset" maxWidth="Infinity" styleClass="login-button"/>
    </VBox>

    <Label fx:id="messageLabel" styleClass="login-error" text="" wrapText="true"/>

    <Button text="Back to Login" onAction="#handleBack"
            style="-fx-background-color:transparent; -fx-text-fill:#888; -fx-cursor:hand; -fx-underline:true; -fx-padding:0;"/>
</VBox>
