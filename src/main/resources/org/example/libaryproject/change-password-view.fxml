<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.libaryproject.ChangePasswordController"
      stylesheets="@styles.css"
      spacing="14"
      prefWidth="320"
      prefHeight="260">

    <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

    <Label text="Change Password" styleClass="screen-title"/>

    <VBox spacing="10" style="-fx-padding: 8 0 0 0;">
        <PasswordField fx:id="currentPasswordField" promptText="Current password"/>
        <PasswordField fx:id="newPasswordField"     promptText="New password"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="login-error" text="" wrapText="true"/>

    <Button text="Save" onAction="#handleSave" maxWidth="Infinity" styleClass="login-button"/>
</VBox>
